# ==================== 环境变量配置示例 ====================
# 复制此文件为 .env 并填写实际值

# ==================== 应用基础配置 ====================
# 应用名称
EXPO_PUBLIC_APP_NAME=AI情绪日记

# 应用版本
EXPO_PUBLIC_APP_VERSION=1.0.0

# 应用ID（Android包名格式）
EXPO_PUBLIC_APP_BUNDLE_ID=com.emotiondiary.app

# 应用Scheme（用于深链接）
EXPO_PUBLIC_APP_SCHEME=emotiondiary

# ==================== 后端API配置 ====================
# 后端API基础URL（必须配置）
# 示例：
# - 本地开发：http://localhost:9091
# - 局域网：http://192.168.1.100:9091
# - 云服务器：http://9.129.7.228:9091
# - 正式域名：https://api.yourdomain.com
EXPO_PUBLIC_BACKEND_BASE_URL=http://localhost:9000

# API超时时间（毫秒）
EXPO_PUBLIC_API_TIMEOUT=30000

# ==================== 功能开关 ====================
# 是否启用离线模式
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true

# 是否启用AI聊天
EXPO_PUBLIC_ENABLE_AI_CHAT=true

# 是否启用心情分析
EXPO_PUBLIC_ENABLE_MOOD_ANALYSIS=true

# 是否启用定位功能
EXPO_PUBLIC_ENABLE_LOCATION=true

# ==================== 主题配置 ====================
# 主题模式：light, dark, auto
EXPO_PUBLIC_THEME_MODE=auto
