# 服务器端口
PORT=9091

# JWT密钥（生产环境请修改为更复杂的值）
JWT_SECRET=your-secret-key-here

# ========== 豆包ARK API配置 ==========
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=your-ark-api-key-here

# ========== 阿里云DashScope API配置 ==========
# 在 https://dashscope.aliyun.com/ 获取您的API密钥
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# ========== 模型管理系统 ==========
# 系统会自动管理多个模型，根据任务类型和模型状态选择合适的模型
# 支持的模型提供商：豆包ARK、阿里云DashScope
# 任务类型：chat（对话）、diary_generation（日记生成）、mood_analysis（情绪分析）、realtime_voice（实时语音）

# 豆包（火山引擎）实时语音 API 配置
# 请在 https://console.volcengine.com/ 获取您的 API 凭证
VOLCENGINE_APP_ID=your_app_id_here
VOLCENGINE_ACCESS_TOKEN=your_access_token_here
VOLCENGINE_API_KEY=your_api_key_here
