# 服务器端口
PORT=9091

# JWT密钥（生产环境请修改为更复杂的值）
JWT_SECRET=your-secret-key-here

# LLM API 配置
LLM_BASE_URL=https://apis.iflow.cn/v1
LLM_API_KEY=your-api-key-here

# LLM 模型配置（可根据不同功能选择不同模型）
# 可用模型：iFlow-ROME, Qwen3-Coder-Plus, Qwen3-Max, Qwen3-VL-Plus, Kimi-K2-Instruct-0905,
#         Qwen3-Max-Preview, Kimi-K2, DeepSeek-V3.2-Exp, DeepSeek-R1, DeepSeek-V3-671B,
#         Qwen3-32B, Qwen3-235B-A22B-Thinking, Qwen3-235B-A22B-Instruct, Qwen3-235B-A22B
LLM_CHAT_MODEL=Qwen3-Max
LLM_EMOTION_MODEL=Qwen3-Max
LLM_HEALTH_MODEL=Qwen3-Max

# 豆包（火山引擎）实时语音 API 配置
# 请在 https://console.volcengine.com/ 获取您的 API 凭证
VOLCENGINE_APP_ID=your_app_id_here
VOLCENGINE_ACCESS_TOKEN=your_access_token_here
VOLCENGINE_API_KEY=your_api_key_here
